  "title": "IronCache overview",
  "uid": "ironcache-overview",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Latency (tail)",
      "collapsed": false,
      "datasource": null,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Command latency p99 / p99.9 (node)",
      "description": "Tail command-execution latency derived from the ironcache_command_duration_seconds histogram. p99/p99.9 are the operator-facing SLO signal (#546).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(ironcache_command_duration_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "range": true,
          "instant": false,
          "legendFormat": "p99",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.999, sum(rate(ironcache_command_duration_seconds_bucket[5m])) by (le))",
          "refId": "B",
          "range": true,
          "instant": false,
          "legendFormat": "p99.9",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum(rate(ironcache_command_duration_seconds_bucket[5m])) by (le))",
          "refId": "C",
          "range": true,
          "instant": false,
          "legendFormat": "p50",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Command latency p99 per shard (hot-shard detection)",
      "description": "Per-shard p99 from ironcache_shard_command_duration_seconds. A single shard standing out is a hot-shard / key-skew signal in the thread-per-core model.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 8
      },
